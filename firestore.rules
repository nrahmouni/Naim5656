rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { 
      return request.auth != null; 
    }

    function currentUser() { 
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMemberOf(companyId) {
      return isSignedIn() && currentUser().companyId == companyId;
    }

    // --- Validation Blueprints ---
    // (Rest of the validation functions stay same)

    function isValidUser(data) {
      return data.email is string && data.email.size() > 0;
    }

    function isValidProject(data) {
      return data.name is string && data.name.size() > 0 &&
             data.ownerCompanyId is string;
    }

    function isValidDailyReport(data) {
      return data.projectId is string && 
             data.companyId is string &&
             data.encargadoId == request.auth.uid;
    }

    // --- Collections ---

    // 1. Companies
    match /companies/{companyId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && currentUser().companyId == companyId;
    }

    // 2. Users
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // 3. Projects
    match /projects/{projectId} {
      allow list: if isSignedIn() && (
        resource.data.ownerCompanyId == currentUser().companyId ||
        exists(/databases/$(database)/documents/project_companies/$(projectId + '_' + currentUser().companyId))
      );
      allow get: if isSignedIn() && (
        resource.data.ownerCompanyId == currentUser().companyId ||
        exists(/databases/$(database)/documents/project_companies/$(projectId + '_' + currentUser().companyId))
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.ownerCompanyId == currentUser().companyId;
    }

    // 4. Project Companies (Relations)
    match /project_companies/{relationId} {
      allow read, write: if isSignedIn();
    }

    // 5. Workers
    match /workers/{workerId} {
      allow list: if isSignedIn() && resource.data.companyId == currentUser().companyId;
      allow get: if isSignedIn() && resource.data.companyId == currentUser().companyId;
      allow create, update, delete: if isSignedIn() && 
                             (incoming().companyId == currentUser().companyId || resource.data.companyId == currentUser().companyId);
    }

    // 6. Daily Reports
    match /daily_reports/{reportId} {
      allow list: if isSignedIn() && (
        resource.data.companyId == currentUser().companyId ||
        resource.data.mainCompanyId == currentUser().companyId
      );
      allow get: if isSignedIn() && (
        resource.data.companyId == currentUser().companyId ||
        resource.data.mainCompanyId == currentUser().companyId
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.companyId == currentUser().companyId;
      
      match /entries/{entryId} {
        allow read, write: if isSignedIn();
      }
    }

    // 7. Delivery Notes
    match /delivery_notes/{noteId} {
      allow list: if isSignedIn() && (
        resource.data.subcontractorId == currentUser().companyId ||
        resource.data.mainCompanyId == currentUser().companyId
      );
      allow get: if isSignedIn() && (
        resource.data.subcontractorId == currentUser().companyId ||
        resource.data.mainCompanyId == currentUser().companyId
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    // 8. Incidents
    match /incidents/{incidentId} {
      allow list, get, create: if isSignedIn();
    }

    // 9. Audit Logs
    match /audit_logs/{logId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || currentUser().role == 'CONSTRUCTORA');
      allow create: if isSignedIn();
    }
  }
}
