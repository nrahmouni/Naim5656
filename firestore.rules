rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { 
      return request.auth != null; 
    }

    function getUserData(uid) { 
      return exists(/databases/$(database)/documents/users/$(uid)) 
        ? get(/databases/$(database)/documents/users/$(uid)).data 
        : null;
    }

    function currentUser() { 
      let data = getUserData(request.auth.uid);
      return data != null ? data : {"role": "GUEST", "companyId": "PENDING"};
    }

    function incoming() { 
      return request.resource.data; 
    }

    function existing() { 
      return resource.data; 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isMemberOf(companyId) {
      return isSignedIn() && currentUser().companyId == companyId;
    }

    // Checks if the user's company is associated with a specific project
    function isProjectMember(projectId) {
      return isSignedIn() && (
        // Project owner
        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerCompanyId == currentUser().companyId ||
        // Associated sub-contractor
        exists(/databases/$(database)/documents/project_companies/$(projectId + '_' + currentUser().companyId))
      );
    }

    // --- Validation Blueprints ---

    function isValidCompany(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.cif is string && data.cif.size() >= 9 && data.cif.size() <= 20 &&
             data.role in ['CONSTRUCTORA', 'SUBCONTRATA'];
    }

    function isValidUser(data) {
      return data.email is string && data.email.size() > 0 &&
             (data.companyId == null || isValidId(data.companyId));
    }

    function isValidProject(data) {
      return data.name is string && data.name.size() > 0 &&
             data.ownerCompanyId is string && isValidId(data.ownerCompanyId);
    }

    function isValidWorker(data) {
      return data.name is string && data.name.size() > 0 &&
             data.companyId is string && isValidId(data.companyId);
    }

    function isValidDailyReport(data) {
      return data.projectId is string && isValidId(data.projectId) &&
             data.companyId is string && isValidId(data.companyId) &&
             data.encargadoId == request.auth.uid &&
             data.status in ['DRAFT', 'SIGNED'];
    }

    function isValidDeliveryNote(data) {
      return data.status in ['DRAFT', 'PENDING', 'DISPUTED', 'APPROVED', 'SIGNED'];
    }

    // --- Collections ---

    // 1. Companies
    match /companies/{companyId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidCompany(incoming());
      allow update: if isMemberOf(companyId) && isValidCompany(incoming());
    }

    // 2. Users
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
    }

    // 3. Projects
    match /projects/{projectId} {
      allow list: if isSignedIn(); // Filtered by companyId in queries
      allow get: if isSignedIn() && (
        resource.data.ownerCompanyId == currentUser().companyId ||
        exists(/databases/$(database)/documents/project_companies/$(projectId + '_' + currentUser().companyId))
      );
      allow create: if isSignedIn() && currentUser().role == 'CONSTRUCTORA' && isValidProject(incoming());
      allow update: if isSignedIn() && resource.data.ownerCompanyId == currentUser().companyId && isValidProject(incoming());
    }

    // 4. Project Companies (Relations)
    match /project_companies/{relationId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create, delete: if isSignedIn() && currentUser().role == 'CONSTRUCTORA';
    }

    // 5. Workers
    match /workers/{workerId} {
      allow list: if isSignedIn() && resource.data.companyId == currentUser().companyId;
      allow get: if isSignedIn() && resource.data.companyId == currentUser().companyId;
      allow create, update: if isSignedIn() && 
                            currentUser().companyId == incoming().companyId && 
                            isValidWorker(incoming());
      allow delete: if isSignedIn() && resource.data.companyId == currentUser().companyId;
    }

    // 6. Daily Reports
    match /daily_reports/{reportId} {
      allow list: if isSignedIn() && (
        resource.data.companyId == currentUser().companyId ||
        resource.data.mainCompanyId == currentUser().companyId
      );
      allow get: if isSignedIn() && (
        resource.data.companyId == currentUser().companyId ||
        resource.data.mainCompanyId == currentUser().companyId
      );
      allow create: if isSignedIn() && isValidDailyReport(incoming());
      allow update: if isSignedIn() && 
                    resource.data.companyId == currentUser().companyId &&
                    existing().status != 'SIGNED' && 
                    isValidDailyReport(incoming());
      
      match /entries/{entryId} {
        allow read, write: if isSignedIn();
      }
    }

    // 7. Delivery Notes
    match /delivery_notes/{noteId} {
      allow list: if isSignedIn() && (
        resource.data.subcontractorId == currentUser().companyId ||
        resource.data.mainCompanyId == currentUser().companyId
      );
      allow get: if isSignedIn() && (
        resource.data.subcontractorId == currentUser().companyId ||
        resource.data.mainCompanyId == currentUser().companyId
      );
      allow create: if isSignedIn() && currentUser().role == 'CONSTRUCTORA' && isValidDeliveryNote(incoming());
      allow update: if isSignedIn() && (
        (incoming().subcontractorId == currentUser().companyId && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'disputeReason', 'signatureBase64']))
        || 
        (currentUser().role == 'CONSTRUCTORA' && existing().status == 'DISPUTED')
      );
    }

    // 8. Incidents
    match /incidents/{incidentId} {
      allow list, get: if isProjectMember(resource.data.projectId);
      allow create: if isProjectMember(incoming().projectId);
    }

    // 9. Audit Logs
    match /audit_logs/{logId} {
      allow list: if isSignedIn() && currentUser().role == 'CONSTRUCTORA';
      allow get: if isSignedIn() && (currentUser().role == 'CONSTRUCTORA' || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
    }
  }
}
